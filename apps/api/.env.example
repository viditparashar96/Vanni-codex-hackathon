# Vaani API (@vaani/api)
PORT=4000
NODE_ENV=development

# Dashboard origin allowed to send credentialed requests
CLIENT_URL=http://localhost:3000

# Public base URL the voice engine uses to reach this API's internal callbacks
PUBLIC_API_URL=http://localhost:4000

# Voice engine base URL (apps/voice-engine)
VOICE_ENGINE_URL=http://localhost:7860

# Postgres (Neon in prod)
DATABASE_URL=postgresql://user:password@localhost:5432/vaani

# Redis (optional — BullMQ workers disabled when unset)
REDIS_URL=redis://localhost:6379

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
