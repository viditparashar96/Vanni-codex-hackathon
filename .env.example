# ───────────────────────────────────────────────────────────────────────────
# Vaani — environment. Copy to .env and fill in. Never commit .env.
# ───────────────────────────────────────────────────────────────────────────

# ── Shared infra ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vaani:vaani@localhost:5432/vaani
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── api (Express platform API) ──────────────────────────────────────────────
PORT=4000
PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
# 32-byte hex key for AES-256-GCM credential encryption (openssl rand -hex 32)
ENCRYPTION_KEY=
# Internal URL the API uses to dispatch calls to the voice engine
VOICE_ENGINE_URL=http://localhost:7860

# ── Media plane (LiveKit) ─────────────────────────────────────────────────────
# Point at LiveKit Cloud or a self-hosted SFU. Switching is env-only.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_local_only_change_me

# ── voice-engine (Python pipeline) ────────────────────────────────────────────
# Internal URL the engine uses to POST end-of-call reports / events back to the API
PLATFORM_API_URL=http://localhost:4000
# Platform-default provider keys (org BYO keys override these at runtime)
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# ── AI Composer (api) ─────────────────────────────────────────────────────────
COMPOSER_MODEL=
COMPOSER_TITLE_MODEL=
COMPOSER_MAX_STEPS=15
COMPOSER_TURN_CAP=200
COMPOSER_ORG_DAILY_INPUT_TOKENS=1000000
COMPOSER_ORG_DAILY_OUTPUT_TOKENS=200000
TAVILY_API_KEY=

# ── Object storage (recordings, KB documents) ─────────────────────────────────
BLOB_STORAGE_PROVIDER=azure
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=vaani

# ── web (Next.js dashboard) ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
